# ====================== 方法9：Prompt Engineering 零样本大模型打分 ======================
def run_prompt_eng(val_df, test_df):
    llm = pipeline("text-generation", model=LLM_PROMPT_MODEL, device=0 if torch.cuda.is_available() else -1)
    prompt_template = """
任务：判断两段中文句子语义匹配程度，输出0~1小数，仅输出数字。
句子1：{s1}
句子2：{s2}
语义相似度分数：
"""
    def get_score(s1,s2):
        prompt = prompt_template.format(s1=s1, s2=s2)
        res = llm(prompt, max_new_tokens=5, temperature=0.0)[0]["generated_text"]
        try:
            num = float(res.split("语义相似度分数：")[-1].strip())
            return max(min(num,1.0),0.0)
        except:
            return 0.5
    val_scores = [get_score(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [get_score(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【9.Prompt Engineering零样本】最优阈值={th:.2f} | {met}")
    return met

# ====================== 方法10：Few-shot 少量样例提示 ======================
def run_fewshot(val_df, test_df, train_df):
    # 抽取5条少量样本作为few-shot示例
    shot_sample = train_df.sample(n=5, random_state=SEED).reset_index(drop=True)
    shot_prompt = ""
    for _,row in shot_sample.iterrows():
        shot_prompt += f"""
句子1：{row['text_a']}
句子2：{row['text_b']}
相似度分数：{row['label']}.0
"""
    llm = pipeline("text-generation", model=LLM_PROMPT_MODEL, device=0 if torch.cuda.is_available() else -1)
    def get_score_few(s1,s2):
        full_prompt = shot_prompt + f"""
句子1：{s1}
句子2：{s2}
相似度分数：
"""
        res = llm(full_prompt, max_new_tokens=5, temperature=0.0)[0]["generated_text"]
        try:
            num = float(res.split("相似度分数：")[-1].strip())
            return max(min(num,1.0),0.0)
        except:
            return 0.5
    val_scores = [get_score_few(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [get_score_few(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【10.Few-shot小样本提示】最优阈值={th:.2f} | {met}")
    return met

