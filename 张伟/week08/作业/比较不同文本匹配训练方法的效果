# ====================== 方法6：BiEncoder BGE双塔 ======================
def run_biencoder(val_df, test_df):
    model = SentenceTransformer(BGE_MODEL, device=device)
    def sim(a,b):
        emb1 = model.encode(a, convert_to_tensor=True)
        emb2 = model.encode(b, convert_to_tensor=True)
        return float(util.cos_sim(emb1, emb2)[0][0])
    val_scores = [sim(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [sim(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【6.BiEncoder-BGE】最优阈值={th:.2f} | {met}")
    return met

# ====================== 方法7：CrossEncoder 交叉编码器微调 ======================
def run_crossencoder(train_df, val_df, test_df):
    tokenizer = AutoTokenizer.from_pretrained(CROSS_MODEL)
    model = AutoModelForSequenceClassification.from_pretrained(CROSS_MODEL).to(device)
    optimizer = torch.optim.AdamW(model.parameters(), lr=2e-5)
    ds_train = Dataset.from_pandas(train_df)
    def tok_fn(ex):
        return tokenizer(ex["text_a"], ex["text_b"], max_length=128, truncation=True, padding="max_length")
    ds_train = ds_train.map(tok_fn)
    loader = torch.utils.data.DataLoader(ds_train, batch_size=8, shuffle=True)
    # 微调3轮
    for ep in range(3):
        model.train()
        loss_sum = 0
        for batch in loader:
            b = {k:v.to(device) for k,v in batch.items() if k!="text_a" and k!="text_b"}
            out = model(**b, labels=batch["label"].to(device))
            loss = out.loss
            loss.backward()
            optimizer.step()
            optimizer.zero_grad()
            loss_sum += loss.item()
        print(f"CrossEncoder Epoch{ep+1} loss:{loss_sum/len(loader):.4f}")
    model.eval()
    def score(a,b):
        inp = tokenizer(a,b,return_tensors="pt",truncation=True,padding=True).to(device)
        with torch.no_grad():
            logits = model(**inp).logits
        return torch.softmax(logits,dim=-1)[0][1].item()
    val_scores = [score(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [score(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【7.CrossEncoder微调】最优阈值={th:.2f} | {met}")
    return met

