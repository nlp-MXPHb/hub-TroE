# ====================== 1. 加载LCQMC jsonl数据集 ======================
def load_jsonl_data(file_path):
    data_list = []
    with open(file_path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            item = json.loads(line)
            data_list.append({
                "text_a": item["sentence1"],
                "text_b": item["sentence2"],
                "label": int(item["label"])
            })
    df = pd.DataFrame(data_list)
    df["text_a"] = df["text_a"].astype(str).str.strip()
    df["text_b"] = df["text_b"].astype(str).str.strip()
    df = df[(df["text_a"] != "") & (df["text_b"] != "")]
    return df

def load_all_split():
    print("读取训练集...")
    train_df = load_jsonl_data(TRAIN_PATH)
    print("读取验证集...")
    val_df = load_jsonl_data(VAL_PATH)
    print("读取测试集...")
    test_df = load_jsonl_data(TEST_PATH)
    print(f"训练集:{len(train_df)} 验证集:{len(val_df)} 测试集:{len(test_df)}")
    return train_df, val_df, test_df

# ====================== 2. 统一评估工具 ======================
def calc_metrics(y_true, y_pred, y_pred_proba=None):
    acc = accuracy_score(y_true, y_pred)
    pre = precision_score(y_true, y_pred, zero_division=0)
    rec = recall_score(y_true, y_pred, zero_division=0)
    f1 = f1_score(y_true, y_pred, zero_division=0)
    auc = roc_auc_score(y_true, y_pred_proba) if y_pred_proba is not None else np.nan
    return {
        "Acc": round(acc,4), "Precision": round(pre,4),
        "Recall": round(rec,4), "F1": round(f1,4), "AUC": round(auc,4)
    }

def select_best_threshold(val_scores, val_labels):
    best_f1 = -1
    best_th = 0.5
    for th in np.arange(0, 1.01, 0.01):
        pred = (np.array(val_scores) >= th).astype(int)
        f1 = f1_score(val_labels, pred, zero_division=0)
        if f1 > best_f1:
            best_f1 = f1
            best_th = th
    return best_th

# ====================== 方法1：编辑距离 Levenshtein ======================
def levenshtein_sim(a,b):
    dist = Levenshtein.distance(a,b)
    maxl = max(len(a),len(b))
    return 1 - dist/maxl if maxl !=0 else 1.0

def run_levenshtein(val_df, test_df):
    val_scores = [levenshtein_sim(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [levenshtein_sim(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【1.编辑距离】最优阈值={th:.2f} | {met}")
    return met

# ====================== 方法2：TF-IDF余弦相似度 ======================
def run_tfidf(train_df, val_df, test_df):
    corpus = list(train_df["text_a"]) + list(train_df["text_b"])
    tfidf = TfidfVectorizer()
    tfidf.fit(corpus)
    def cos(a,b):
        va = tfidf.transform([a]).toarray()[0]
        vb = tfidf.transform([b]).toarray()[0]
        dot = np.dot(va,vb)
        norm = np.linalg.norm(va)*np.linalg.norm(vb)
        return dot/norm if norm !=0 else 0.0
    val_scores = [cos(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [cos(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【2.TF-IDF】最优阈值={th:.2f} | {met}")
    return met

# ====================== 方法3：BM25 ======================
def run_bm25(train_df, val_df, test_df):
    all_text = list(train_df["text_a"]) + list(train_df["text_b"])
    tokenized = [list(t) for t in all_text]
    bm25 = BM25Okapi(tokenized)
    def score(a,b):
        q = list(a)
        return bm25.get_scores(q)[0]
    val_scores = [score(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [score(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【3.BM25】最优阈值={th:.2f} | {met}")
    return met

# ====================== 工具：词向量均值通用函数 ======================
def get_avg_vec(text, w2v_model, dim):
    words = list(text)
    vecs = []
    for w in words:
        if w in w2v_model.wv:
            vecs.append(w2v_model.wv[w])
    if len(vecs)==0:
        return np.zeros(dim)
    return np.mean(vecs, axis=0)

# ====================== 方法4：Word2Vec 均值向量 ======================
def run_word2vec(train_df, val_df, test_df):
    # 训练简易word2vec
    all_corpus = [list(s) for s in list(train_df["text_a"])+list(train_df["text_b"])]
    w2v = gensim.models.Word2Vec(all_corpus, vector_size=64, window=3, min_count=1, seed=SEED)
    dim = 64
    def cos_sim(a,b):
        va = get_avg_vec(a, w2v, dim)
        vb = get_avg_vec(b, w2v, dim)
        dot = np.dot(va,vb)
        norm = np.linalg.norm(va)*np.linalg.norm(vb)
        return dot/norm if norm !=0 else 0.0
    val_scores = [cos_sim(r["text_a"],r["text_b"]) for _,r in val_df.iterrows()]
    th = select_best_threshold(val_scores, val_df["label"])
    test_scores = [cos_sim(r["text_a"],r["text_b"]) for _,r in test_df.iterrows()]
    pred = (np.array(test_scores)>=th).astype(int)
    met = calc_metrics(test_df["label"], pred, test_scores)
    print(f"\n【4.Word2Vec均值】最优阈值={th:.2f} | {met}")
    return met

